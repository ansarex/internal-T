---
import AuthLayout from '../layouts/AuthLayout.astro';
---
<AuthLayout title="Verify Email">
  <div id="verify-container" class="bg-white rounded-xl shadow p-8 text-center">
    <p class="text-gray-500">Verifying your email...</p>
  </div>
  <script>
    (async () => {
      const params = new URLSearchParams(window.location.search);
      const id = params.get('id');
      const hash = params.get('hash');
      const expires = params.get('expires');
      const signature = params.get('signature');

      const container = document.getElementById('verify-container');

      if (!id || !hash) {
        container!.innerHTML = '<p class="text-red-600">Invalid verification link.</p>';
        return;
      }

      try {
        const apiUrl = (import.meta.env.PUBLIC_API_URL || 'http://localhost:8080');
        const response = await fetch(
          `${apiUrl}/api/email/verify/${id}/${hash}?expires=${expires}&signature=${signature}`
        );
        const data = await response.json();

        if (response.ok) {
          container!.innerHTML = `
            <div class="text-green-600 text-xl font-semibold mb-2">Email Verified!</div>
            <p class="text-gray-500 mb-4">${data.message}</p>
            <a href="/login" class="inline-block bg-blue-600 text-white px-6 py-2 rounded-lg hover:bg-blue-700">
              Go to Login
            </a>
          `;
        } else {
          container!.innerHTML = `
            <div class="text-red-600 text-xl font-semibold mb-2">Verification Failed</div>
            <p class="text-gray-500 mb-4">${data.message}</p>
            <p class="text-gray-500 text-sm mb-3">Enter your email to get a new verification link.</p>
            <form id="resend-form" class="flex flex-col items-center gap-3">
              <input
                id="resend-email"
                type="email"
                required
                placeholder="you@example.com"
                class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 text-sm"
              />
              <button
                type="submit"
                id="resend-btn"
                class="w-full bg-blue-600 text-white py-2 px-4 rounded-lg hover:bg-blue-700 text-sm font-medium"
              >
                Resend verification email
              </button>
              <div id="resend-msg" class="text-sm"></div>
            </form>
          `;
          document.getElementById('resend-form')!.addEventListener('submit', async (e) => {
            e.preventDefault();
            const emailInput = document.getElementById('resend-email') as HTMLInputElement;
            const btn = document.getElementById('resend-btn') as HTMLButtonElement;
            const msg = document.getElementById('resend-msg')!;
            btn.disabled = true;
            btn.textContent = 'Sending…';
            msg.textContent = '';
            try {
              await fetch(`${apiUrl}/api/email/resend-verification`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ email: emailInput.value }),
              });
              msg.className = 'text-sm text-green-600';
              msg.textContent = 'Verification email sent. Check your inbox.';
            } catch {
              msg.className = 'text-sm text-red-600';
              msg.textContent = 'Failed to send. Please try again.';
            } finally {
              btn.disabled = false;
              btn.textContent = 'Resend verification email';
            }
          });
        }
      } catch (e) {
        container!.innerHTML = '<p class="text-red-600">An error occurred. Please try again.</p>';
      }
    })();
  </script>
</AuthLayout>

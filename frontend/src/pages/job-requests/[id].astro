---
import AppLayout from '../../layouts/AppLayout.astro';
import AppSidebar from '../../components/shared/AppSidebar.vue';
import JobRequestDetail from '../../components/job-requests/JobRequestDetail.vue';

const { id } = Astro.params;
---
<AppLayout title={`Job Request #${id}`}>
  <div class="flex min-h-screen">
    <AppSidebar client:only="vue" />
    <main class="flex-1 p-6 overflow-auto">
      <JobRequestDetail jobId={Number(id)} client:only="vue" />
    </main>
  </div>
</AppLayout>

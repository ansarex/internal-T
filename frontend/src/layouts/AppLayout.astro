---
export interface Props {
  title?: string;
}
const { title = 'Dashboard' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — Trustwired</title>
</head>
<body class="min-h-screen bg-[#f4f5f7]">
  <div id="app-layout">
    <slot />
  </div>
  <script>
    // Client-side auth guard
    const token = localStorage.getItem('auth_token');
    if (!token && !window.location.pathname.startsWith('/login') && !window.location.pathname.startsWith('/forgot') && !window.location.pathname.startsWith('/reset') && !window.location.pathname.startsWith('/verify')) {
      window.location.href = '/login';
    }
  </script>
</body>
</html>
